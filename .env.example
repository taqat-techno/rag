# RAG Tools Configuration
# Copy to .env and modify as needed. All values have sensible defaults.

# RAG_QDRANT_PATH=data/qdrant
# RAG_COLLECTION_NAME=markdown_kb
# RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
# RAG_EMBEDDING_DIM=384
# RAG_CHUNK_SIZE=400
# RAG_CHUNK_OVERLAP=100
# RAG_CONTENT_ROOT=.
# RAG_TOP_K=10
# RAG_SCORE_THRESHOLD=0.3
# RAG_STATE_DB=data/index_state.db

# Ignore rules
# RAG_IGNORE_PATTERNS=["drafts/","*.tmp"]
# RAG_USE_RAGIGNORE_FILES=true

# Service
# RAG_SERVICE_HOST=127.0.0.1
# RAG_SERVICE_PORT=21420
# RAG_LOG_LEVEL=INFO

# Startup (Windows Task Scheduler)
# RAG_STARTUP_ENABLED=false
# RAG_STARTUP_DELAY=30
# RAG_STARTUP_WATCHER=true
# RAG_STARTUP_OPEN_BROWSER=false
